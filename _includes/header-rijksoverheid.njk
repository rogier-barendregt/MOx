<header>
    <figure class="logo">
        <a href="/">
            <img src="{{ '/assets/images/beeldmerk-rijksoverheid.svg' | url }}" alt="Naar de homepage van MijnOverheid Zakelijk">
        </a>
    </figure>
    {% if mainNav %}
    <nav class="main-nav">
        <ul>
            {% for item in mainNav %}
            <li><a href="{{ item.url }}"{% if item.current %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
            {% endfor %}
        </ul>
    </nav>
    {% endif %}
</header>
