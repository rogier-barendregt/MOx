
@layer tokens {
  /* These will all generated by Style Dictionary, based on the design tokens from Figma/Tokens Studio in JSON format */

  body {
    /* === BRAND TOKENS (lv 1) === */

    /* Spacing */
    --mox-lint-inline-size: 48px;

    --mox-space-md-min: 1.05rem;
    --mox-space-md-max: 1.25rem;

    /* smaller sizes based on `md` */
    --mox-space-sm-min: calc(var(--mox-space-md-min) * pow(1.2, -1));
    --mox-space-sm-max: calc(var(--mox-space-md-max) * pow(1.2, -1));

    --mox-space-xs-min: calc(var(--mox-space-md-min) * pow(1.2, -2));
    --mox-space-xs-max: calc(var(--mox-space-md-max) * pow(1.2, -2));

    --mox-space-2xs-min: calc(var(--mox-space-md-min) * pow(1.2, -3));
    --mox-space-2xs-max: calc(var(--mox-space-md-max) * pow(1.2, -3));

    --mox-space-3xs-min: calc(var(--mox-space-md-min) * pow(1.2, -4));
    --mox-space-3xs-max: calc(var(--mox-space-md-max) * pow(1.2, -4));

    --mox-space-4xs-min: calc(var(--mox-space-md-min) * pow(1.2, -5));
    --mox-space-4xs-max: calc(var(--mox-space-md-max) * pow(1.2, -5));

    /* larger sizes based on `md` */
    --mox-space-lg-min: calc(var(--mox-space-md-min) * pow(1.2, 1));
    --mox-space-lg-max: calc(var(--mox-space-md-max) * pow(1.2, 1));

    --mox-space-xl-min: calc(var(--mox-space-md-min) * pow(1.2, 2));
    --mox-space-xl-max: calc(var(--mox-space-md-max) * pow(1.2, 2));

    --mox-space-2xl-min: calc(var(--mox-space-md-min) * pow(1.2, 3));
    --mox-space-2xl-max: calc(var(--mox-space-md-max) * pow(1.2, 3));

    --mox-space-3xl-min: calc(var(--mox-space-md-min) * pow(1.2, 4));
    --mox-space-3xl-max: calc(var(--mox-space-md-max) * pow(1.2, 4));

    --mox-space-4xl-min: calc(var(--mox-space-md-min) * pow(1.2, 5));
    --mox-space-4xl-max: calc(var(--mox-space-md-max) * pow(1.2, 5));

    /* brand colors */
    --mox-color-cool-grey-50: #f8fafc;
    --mox-color-cool-grey-100: #f1f5f9;
    --mox-color-cool-grey-200: #e2e8f0;
    --mox-color-cool-grey-300: #cbd5e1;
    --mox-color-cool-grey-400: #94a3b8;
    --mox-color-cool-grey-500: #64748b;
    --mox-color-cool-grey-600: #475569;
    --mox-color-cool-grey-700: #334155;
    --mox-color-cool-grey-800: #1e293b;
    --mox-color-cool-grey-900: #0f172a;
    --mox-color-lichtblauw-50: #eef7fb;
    --mox-color-lichtblauw-100: #ddeff8;
    --mox-color-lichtblauw-200: #cce7f4;
    --mox-color-lichtblauw-300: #bcdff0;
    --mox-color-lichtblauw-400: #abd7ed;
    --mox-color-lichtblauw-500: #8fcae7;
    --mox-color-violet-50: #f2d9e7;
    --mox-color-violet-100: #e5b3d0;
    --mox-color-violet-200: #d88cb7;
    --mox-color-violet-300: #cb66a0;
    --mox-color-violet-400: #be4088;
    --mox-color-violet-500: #a90061;
    --mox-color-paars-50: #e3dce7;
    --mox-color-paars-100: #c6b9cf;
    --mox-color-paars-200: #a995b7;
    --mox-color-paars-300: #8d729f;
    --mox-color-paars-400: #714f87;
    --mox-color-paars-500: #42145f;
    --mox-color-hemelblauw-50: #d9ebf7;
    --mox-color-hemelblauw-100: #b3d7ee;
    --mox-color-hemelblauw-200: #8cc3e6;
    --mox-color-hemelblauw-300: #66afdd;
    --mox-color-hemelblauw-400: #409cd5;
    --mox-color-hemelblauw-500: #007bc7;
    --mox-color-donkerblauw-50: #d9e8f0;
    --mox-color-donkerblauw-100: #b3d2e1;
    --mox-color-donkerblauw-200: #8cbbd2;
    --mox-color-donkerblauw-300: #66a4c3;
    --mox-color-donkerblauw-400: #408eb4;
    --mox-color-donkerblauw-500: #01689b;
    --mox-color-mintgroen-50: #eaf8f4;
    --mox-color-mintgroen-100: #d6f2e9;
    --mox-color-mintgroen-200: #c1ebde;
    --mox-color-mintgroen-300: #ace4d3;
    --mox-color-mintgroen-400: #98ddc8;
    --mox-color-mintgroen-500: #76d2b6;
    --mox-color-mosgroen-50: #ebebd9;
    --mox-color-mosgroen-100: #d6d7b3;
    --mox-color-mosgroen-200: #c1c38c;
    --mox-color-mosgroen-300: #adaf66;
    --mox-color-mosgroen-400: #999c40;
    --mox-color-mosgroen-500: #777b00;
    --mox-color-groen-50: #e1eddb;
    --mox-color-groen-100: #c4dbb6;
    --mox-color-groen-200: #a5c991;
    --mox-color-groen-300: #88b76d;
    --mox-color-groen-400: #6aa549;
    --mox-color-groen-500: #39870c;
    --mox-color-donkergroen-50: #dfe6e1;
    --mox-color-donkergroen-100: #becdc3;
    --mox-color-donkergroen-200: #9db4a4;
    --mox-color-donkergroen-300: #7d9b87;
    --mox-color-donkergroen-400: #5d8269;
    --mox-color-donkergroen-500: #275937;
    --mox-color-bruin-50: #efeada;
    --mox-color-bruin-100: #dfd4b6;
    --mox-color-bruin-200: #cfbf90;
    --mox-color-bruin-300: #bfa96c;
    --mox-color-bruin-400: #af9447;
    --mox-color-bruin-500: #94710a;
    --mox-color-donkerbruin-50: #e8e0df;
    --mox-color-donkerbruin-100: #d1c2be;
    --mox-color-donkerbruin-200: #baa39d;
    --mox-color-donkerbruin-300: #a3847d;
    --mox-color-donkerbruin-400: #8d665d;
    --mox-color-donkerbruin-500: #673327;
    --mox-color-geel-50: #fefbdd;
    --mox-color-geel-100: #fdf6bc;
    --mox-color-geel-200: #fcf199;
    --mox-color-geel-300: #fbed78;
    --mox-color-geel-400: #fae856;
    --mox-color-geel-500: #f9e11e;
    --mox-color-donkergeel-50: #fff4db;
    --mox-color-donkergeel-100: #ffe9b8;
    --mox-color-donkergeel-200: #fdde94;
    --mox-color-donkergeel-300: #fdd370;
    --mox-color-donkergeel-400: #fdc84d;
    --mox-color-donkergeel-500: #ffb612;
    --mox-color-oranje-50: #fbead9;
    --mox-color-oranje-100: #f6d4b3;
    --mox-color-oranje-200: #f1be8c;
    --mox-color-oranje-300: #eda966;
    --mox-color-oranje-400: #e89440;
    --mox-color-oranje-500: #e17000;
    --mox-color-rood-50: #f9dfdd;
    --mox-color-rood-100: #f2bfbc;
    --mox-color-rood-200: #ec9f99;
    --mox-color-rood-300: #e67f78;
    --mox-color-rood-400: #df6056;
    --mox-color-rood-500: #d52b1e;
    --mox-color-roze-50: #fdeff8;
    --mox-color-roze-100: #fbdef0;
    --mox-color-roze-200: #f8cee8;
    --mox-color-roze-300: #f6bde1;
    --mox-color-roze-400: #f4add9;
    --mox-color-roze-500: #f092cd;
    --mox-color-robijnrood-50: #f7d9e7;
    --mox-color-robijnrood-100: #efb3ce;
    --mox-color-robijnrood-200: #e78cb6;
    --mox-color-robijnrood-300: #df669d;
    --mox-color-robijnrood-400: #d74085;
    --mox-color-robijnrood-500: #ca005d;
    --mox-color-lintblauw-50: #dce3ea;
    --mox-color-lintblauw-100: #b8c6d5;
    --mox-color-lintblauw-200: #95a9c0;
    --mox-color-lintblauw-300: #738eab;
    --mox-color-lintblauw-400: #4f7196;
    --mox-color-lintblauw-500: #154273;

    --mox-color-wit: #ffffff;
    --mox-color-wit-contrast: #000000;
    --mox-color-zwart: #000000;
    --mox-color-zwart-contrast: #ffffff;
    --mox-color-transparent: rgba(0, 0, 0, 0);
    --mox-color-transparant: #000000;

    --mox-border-radius-round: 999px;
    --mox-border-radius-none: 0px;
    --mox-border-radius-sm: 2.5px;
    --mox-border-radius-md: 5px;
1    --mox-border-width-md: 2px;
    --mox-border-width-none: 0px;

    /* === COMMON (SEMANTIC) TOKENS (lv 2) ===
    
    colors - misschien 'subtle' anders noemen (bv 'muted')
    Voor nu leek me dit lijstje voldoende:
    - primary (+2 subtile-variaties)
    - secondary (+2 subtile-variaties)
    - neutral (+2 subtile-variaties)
    - accent (+2 subtile-variaties)
    - info
    - success 
    - warning
    - danger;

    */
    --mox-color-primary: var(--mox-color-hemelblauw-500);
    --mox-color-primary-contrast: var(--mox-color-wit);
    --mox-color-primary-subtle: var(--mox-color-hemelblauw-200);
    --mox-color-primary-subtle-contrast: var(--mox-color-black);
    --mox-color-primary-subtle-2: var(--mox-color-hemelblauw-100);
    --mox-color-primary-subtle-2-contrast: var(--mox-color-black);
    --mox-color-primary-hover: var(--mox-color-hemelblauw-400);
    --mox-color-primary-hover-contrast: var(--mox-color-wit);
    --mox-color-primary-subtle-hover: var(--mox-color-hemelblauw-100);
    --mox-color-primary-subtle-hover-contrast: var(--mox-color-black);
    --mox-color-primary-subtle-2-hover: var(--mox-color-hemelblauw-50);
    --mox-color-primary-subtle-2-hover-contrast: var(--mox-color-black);

    --mox-color-secondary: var(--mox-color-paars-500);
    --mox-color-secondary-contrast: var(--mox-color-wit);
    --mox-color-secondary-subtle: var(--mox-color-paars-200);
    --mox-color-secondary-subtle-contrast: var(--mox-color-black);
    --mox-color-secondary-subtle-2: var(--mox-color-paars-100);
    --mox-color-secondary-subtle-2-contrast: var(--mox-color-black);
    --mox-color-secondary-hover: var(--mox-color-paars-400);
    --mox-color-secondary-hover-contrast: var(--mox-color-wit);
    --mox-color-secondary-subtle-hover: var(--mox-color-paars-100);
    --mox-color-secondary-subtle-hover-contrast: var(--mox-color-black);
    --mox-color-secondary-subtle-2-hover: var(--mox-color-paars-50);
    --mox-color-secondary-subtle-2-hover-contrast: var(--mox-color-black);

    --mox-color-neutral: var(--mox-color-cool-grey-300);
    --mox-color-neutral-contrast: var(--mox-color-wit);
    --mox-color-neutral-subtle: var(--mox-color-cool-grey-200);
    --mox-color-neutral-subtle-contrast: var(--mox-color-black);
    --mox-color-neutral-subtle-2: var(--mox-color-cool-grey-100);
    --mox-color-neutral-subtle-2-contrast: var(--mox-color-black);
    --mox-color-neutral-hover: var(--mox-color-cool-grey-400);
    --mox-color-neutral-hover-contrast: var(--mox-color-wit);
    --mox-color-neutral-subtle-hover: var(--mox-color-cool-grey-100);
    --mox-color-neutral-subtle-hover-contrast: var(--mox-color-black);
    --mox-color-neutral-subtle-2-hover: var(--mox-color-cool-grey-50);
    --mox-color-neutral-subtle-2-hover-contrast: var(--mox-color-black);

    --mox-color-accent: var(--mox-color-mintgroen-500);
    --mox-color-accent-contrast: var(--mox-color-wit);
    --mox-color-accent-subtle: var(--mox-color-mintgroen-200);
    --mox-color-accent-subtle-contrast: var(--mox-color-black);
    --mox-color-accent-subtle-2: var(--mox-color-mintgroen-100);
    --mox-color-accent-subtle-2-contrast: var(--mox-color-black);
    --mox-color-accent-hover: var(--mox-color-mintgroen-400);
    --mox-color-accent-hover-contrast: var(--mox-color-wit);
    --mox-color-accent-subtle-hover: var(--mox-color-mintgroen-100);
    --mox-color-accent-subtle-hover-contrast: var(--mox-color-black);
    --mox-color-accent-subtle-2-hover: var(--mox-color-mintgroen-50);
    --mox-color-accent-subtle-2-hover-contrast: var(--mox-color-black);

    --mox-color-info: var(--mox-color-lichtblauw-500);
    --mox-color-info-contrast: var(--mox-color-zwart);
    --mox-color-info-subtle: var(--mox-color-lichtblauw-200);
    --mox-color-info-subtle-contrast: var(--mox-color-zwart);
    --mox-color-info-subtle-2: var(--mox-color-lichtblauw-100);
    --mox-color-info-subtle-2-contrast: var(--mox-color-zwart);
    --mox-color-info-hover: var(--mox-color-lichtblauw-400);
    --mox-color-info-hover-contrast: var(--mox-color-zwart);
    --mox-color-info-subtle-hover: var(--mox-color-lichtblauw-100);
    --mox-color-info-subtle-hover-contrast: var(--mox-color-zwart);
    --mox-color-info-subtle-2-hover: var(--mox-color-lichtblauw-50);
    --mox-color-info-subtle-2-hover-contrast: var(--mox-color-zwart);

    --mox-color-success: var(--mox-color-groen-500);
    --mox-color-success-contrast: var(--mox-color-wit);
    --mox-color-success-subtle: var(--mox-color-groen-200);
    --mox-color-success-subtle-contrast: var(--mox-color-zwart);
    --mox-color-success-subtle-2: var(--mox-color-groen-100);
    --mox-color-success-subtle-2-contrast: var(--mox-color-zwart);
    --mox-color-success-hover: var(--mox-color-groen-400);
    --mox-color-success-hover-contrast: var(--mox-color-wit);
    --mox-color-success-subtle-hover: var(--mox-color-groen-100);
    --mox-color-success-subtle-hover-contrast: var(--mox-color-zwart);
    --mox-color-success-subtle-2-hover: var(--mox-color-groen-50);
    --mox-color-success-subtle-2-hover-contrast: var(--mox-color-zwart);

    --mox-color-warning: var(--mox-color-geel-500);
    --mox-color-warning-contrast: var(--mox-color-zwart);
    --mox-color-warning-subtle: var(--mox-color-geel-200);
    --mox-color-warning-subtle-contrast: var(--mox-color-zwart);
    --mox-color-warning-subtle-2: var(--mox-color-geel-100);
    --mox-color-warning-subtle-2-contrast: var(--mox-color-zwart);
    --mox-color-warning-hover: var(--mox-color-geel-400);
    --mox-color-warning-hover-contrast: var(--mox-color-zwart);
    --mox-color-warning-subtle-hover: var(--mox-color-geel-100);
    --mox-color-warning-subtle-hover-contrast: var(--mox-color-zwart);
    --mox-color-warning-subtle-2-hover: var(--mox-color-geel-50);
    --mox-color-warning-subtle-2-hover-contrast: var(--mox-color-zwart);

    --mox-color-danger: var(--mox-color-rood-500);
    --mox-color-danger-contrast: var(--mox-color-wit);
    --mox-color-danger-subtle: var(--mox-color-rood-200);
    --mox-color-danger-subtle-contrast: var(--mox-color-zwart);
    --mox-color-danger-subtle-2: var(--mox-color-rood-100);
    --mox-color-danger-subtle-2-contrast: var(--mox-color-zwart);
    --mox-color-danger-hover: var(--mox-color-rood-400);
    --mox-color-danger-hover-contrast: var(--mox-color-wit);
    --mox-color-danger-subtle-hover: var(--mox-color-rood-100);
    --mox-color-danger-subtle-hover-contrast: var(--mox-color-zwart);
    --mox-color-danger-subtle-2-hover: var(--mox-color-rood-50);
    --mox-color-danger-subtle-2-hover-contrast: var(--mox-color-zwart);

    /* Foxus */
    --mox-focus-color: var(--mox-color-orange-500);

    /* Page grid */
    --mox-layout-page-grid-gap: var(--mox-space-3xs);
    --mox-layout-page-grid-gap-tablet: var(--mox-space-xs);
    --mox-layout-page-grid-gap-desktop: var(--mox-space-md);
    --mox-layout-page-grid-max-width: 1200px;

    /* Container grid */
    --mox-layout-container-grid-gap: var(--mox-space-3xs);
    --mox-layout-container-grid-gap-400px: var(--mox-space-xs);
    --mox-layout-container-grid-gap-600px: var(--mox-space-md);
    --mox-layout-container-grid-gap-800px: var(--mox-space-xl);

    /* === COMPONENT TOKENS (lv 3) === */

    /* Form stuff (om 'checkbox' en 'radio' samen te targetten noem ik ze 'option' - je wilt nooit dat checkbox/radio een andere border color hebben bijvoobeeld) */
    --mox-form-input-option-border-color: var(--mox-color-primary);
    --mox-form-input-checkbox-radius: var(--mox-border-radius-sm);
    --mox-form-input-option-size: var(--mox-space-sm);
    --mox-form-input-option-checked-color: var(--mox-color-primary);
    --mox-form-input-option-checked-color-contrast: var(
      --mox-color-primary-contrast
    );
  }
}